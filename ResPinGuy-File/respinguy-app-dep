#!/bin/bash
allow_only_root() {
  if [ "0$UID" -ne 0 ]; then echo "Merci d'être en root pour lancer : $(basename $0)"; exit 1; fi
}
allow_only_root
echo "Vérification des dépendances..."
ERRORS=0
check() {
  if [ ! $(type -p $1) ]; then echo "[MANQUANT] $1"; ERRORS=$((ERRORS+1)); else echo "[OK] $1"; fi
}
check git
check wget
check bash
check sh
check nano
check uname
check dracut
check xorriso
if [ "$(mksquashfs 2>&1 | grep 'Xdict-size')" = "" ]; then
  echo "[MANQUANT] mksquashfs (ou sans support xz)"; ERRORS=$((ERRORS+1))
else
  echo "[OK] mksquashfs"
fi
echo "---"
if [ $ERRORS -eq 0 ]; then
  echo "Toutes les dépendances sont installées."; exit 0
else
  echo "$ERRORS dépendance(s) manquante(s)."
  echo "Utilisez : /usr/share/ResPinGuy-File/respinguy-app-dep-force-install"
  exit 1
fi
