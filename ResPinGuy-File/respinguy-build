#!/bin/bash
#_____________________________________________________________________________________________
# ResPinGuy - Build
allow_only_root() {
  if [ "0$UID" -ne 0 ]; then
     echo "Merci d'être en root pour lancer : $(basename $0)"; exit 1
  fi
}
allow_only_root

cd /usr/share/ResPinGuy-File-Config/ || exit 1
. ./respinguy-config || exit 1

bash /usr/share/ResPinGuy-File/respinguy-app-dep
if [ $? -ne 0 ]; then echo "[ERREUR] Dépendances manquantes. Build annulé."; exit 1; fi

if [ ! "$(dracut --list-modules 2>/dev/null | grep squash)" ]; then
    echo "[ERREUR] Module dracut manquant : squash"
    echo "         Debian/Ubuntu : apt install dracut-live"
    echo "         Fedora/RHEL   : dnf install dracut-live dracut-squash"
    echo "         Arch          : pacman -S dracut"
    exit 1
fi
if [ ! "$(dracut --list-modules 2>/dev/null | grep dmsquash-live)" ]; then
    echo "[ERREUR] Module dracut manquant : dmsquash-live"
    echo "         Debian/Ubuntu : apt install dracut-live"
    echo "         Fedora/RHEL   : dnf install dracut-live"
    echo "         Arch          : pacman -S dracut"
    exit 1
fi

if [ ! -f "$VMLINUZ" ]; then
    echo "[ERREUR] Kernel introuvable : $VMLINUZ"
    ls /boot/vmlinuz* /boot/kernel* 2>/dev/null
    exit 1
fi

if [ -z "$RPGBUILDNAME" ] || [ -z "$RPGHOME" ] || [ -z "$KERNEL" ]; then
    echo "[ERREUR] Variable RPGBUILDNAME, RPGHOME ou KERNEL non définie."; exit 1
fi
if [ -n "$RPGCONFIGUSER" ] && [ -n "$RPGCONFIGUSERPERS" ]; then
    echo "[ERREUR] RPGCONFIGUSER et RPGCONFIGUSERPERS ne peuvent pas être définis ensemble."; exit 1
fi

clear
echo "_ _ _"
echo "Résumé avant création"
echo "---"
echo "Nom              : $RPGBUILDNAME"
echo "Kernel           : $VMLINUZ"
echo "Version kernel   : $KERNEL"
echo "Architecture     : $ARCH"
echo "Dossiers inclus  : $ROOTDIR"
echo "ISO de sortie    : $RPGHOME"
echo "Dossier de build : /respinguy-build-dir/"
if   [ -n "$RPGCONFIGUSER" ];     then echo "Home utilisateur : $HOME (ISO uniquement)"
elif [ -n "$RPGCONFIGUSERPERS" ]; then echo "Home utilisateur : $HOME (ISO + persistance)"
else                                   echo "Home utilisateur : non inclus"
fi
echo "_ _ _"
rm -rf /respinguy-build-dir/
read -p "Appuyez sur Entrée pour lancer le build..."

cd / || exit 1
mkdir -p /respinguy-build-dir/LiveOS
mkdir -p /respinguy-build-dir/isolinux

echo "Copie des fichiers ISO..."
cp -r /usr/share/ResPinGuy-File/fichier/iso/isolinux/. /respinguy-build-dir/isolinux/
cp /usr/share/ResPinGuy-File-Config/bootimg.png /respinguy-build-dir/isolinux/
cp /usr/share/ResPinGuy-File-Config/isolinux.cfg /respinguy-build-dir/isolinux/

if [ -n "$RPGHOME" ] && [ "$RPGHOME" != "/" ]; then
    rm -rf "$RPGHOME" && mkdir -p "$RPGHOME"
else
    echo "[ERREUR] RPGHOME invalide : '$RPGHOME'"; exit 1
fi

cp "$VMLINUZ" /respinguy-build-dir/vmlinuz || { echo "[ERREUR] Copie kernel impossible."; exit 1; }
echo "Kernel copié."
read -p "Appuyez sur Entrée pour continuer..."
clear

if [ -n "$RPGCONFIGUSER" ]; then
    bash /usr/share/ResPinGuy-File/script/rcu || exit 1
elif [ -n "$RPGCONFIGUSERPERS" ]; then
    bash /usr/share/ResPinGuy-File/script/rcup || exit 1
fi

#_____________________________________________________________________________________________
# PRÉPARATION DU /etc LIVE
# On copie /etc dans un dossier temporaire et on y remplace fstab.
# Le système source n'est JAMAIS modifié.
# mksquashfs reçoit le dossier /etc temporaire à la place du vrai /etc.
echo "Préparation du /etc live (fstab)..."
RPG_ETC_TMP=$(mktemp -d /tmp/rpg-etc.XXXXXX)
cp -a /etc/. "$RPG_ETC_TMP/"

cat > "$RPG_ETC_TMP/fstab" << 'FSTABEOF'
# /etc/fstab - ResPinGuy Live
# Généré automatiquement par ResPinGuy pour le démarrage en mode live.
# Les UUID du système source ont été retirés volontairement.
tmpfs   /tmp     tmpfs   defaults,noatime  0 0
tmpfs   /run     tmpfs   defaults,noatime  0 0
FSTABEOF

echo "[OK] /etc live préparé dans $RPG_ETC_TMP"

# Désactivation des services bloquants en mode live
# systemd cherche les overrides dans /etc/systemd/system/ EN PRIORITÉ sur /lib/systemd/system/
# Un symlink /etc/systemd/system/service.service -> /dev/null masque TOTALEMENT le service,
# même s'il existe dans /lib/systemd/system/
SYSTEMD_DIR="$RPG_ETC_TMP/systemd/system"
mkdir -p "$SYSTEMD_DIR"

# Copie des overrides existants depuis /etc/systemd/system/
if [ -d "/etc/systemd/system/" ]; then
    cp -a /etc/systemd/system/. "$SYSTEMD_DIR/" 2>/dev/null
fi

# Copie également des dossiers .wants et .requires depuis /lib/systemd/system/
# pour qu'on puisse supprimer les liens qui y activent les services bloquants
for WANTS_DIR in /lib/systemd/system/*.wants /lib/systemd/system/*.requires; do
    [ -d "$WANTS_DIR" ] || continue
    DIRNAME=$(basename "$WANTS_DIR")
    mkdir -p "$SYSTEMD_DIR/$DIRNAME"
    cp -a "$WANTS_DIR/." "$SYSTEMD_DIR/$DIRNAME/" 2>/dev/null
done

# Détection de la distro via /etc/os-release
DISTRO_ID=""
DISTRO_LIKE=""
if [ -f /etc/os-release ]; then
    DISTRO_ID=$(grep "^ID=" /etc/os-release | cut -d= -f2 | tr -d '"' | tr '[:upper:]' '[:lower:]')
    DISTRO_LIKE=$(grep "^ID_LIKE=" /etc/os-release | cut -d= -f2 | tr -d '"' | tr '[:upper:]' '[:lower:]')
fi
echo "[INFO] Distro détectée : $DISTRO_ID (famille : $DISTRO_LIKE)"

# Services à désactiver sur TOUTES les distros
SERVICES_COMMON="
    systemd-networkd-wait-online.service
    NetworkManager-wait-online.service
    systemd-resolved.service
"

# Services spécifiques Debian/Ubuntu
SERVICES_DEBIAN="
    rpcbind.service
    rpcbind.socket
    nftables.service
    keyboard-setup.service
    plymouth.service
    plymouth-quit.service
    plymouth-quit-wait.service
"

# Services spécifiques Fedora/RHEL/CentOS
SERVICES_RPM="
    firewalld.service
    rpcbind.service
    rpcbind.socket
    nftables.service
    plymouth.service
    plymouth-quit.service
    plymouth-quit-wait.service
    kdump.service
    abrtd.service
"

# Services spécifiques Arch/Manjaro
SERVICES_ARCH="
    iptables.service
    ip6tables.service
    nftables.service
    systemd-boot-update.service
"

# Services spécifiques OpenSUSE
SERVICES_OPENSUSE="
    firewalld.service
    nftables.service
    rpcbind.service
    rpcbind.socket
    wicked.service
    wickedd.service
"

# Construction de la liste finale selon la distro
SERVICES_TO_MASK="$SERVICES_COMMON"

case "$DISTRO_ID" in
    debian|ubuntu|linuxmint|pop|kali|raspbian|elementary|zorin)
        SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_DEBIAN" ;;
    fedora|rhel|centos|almalinux|rocky|ol)
        SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_RPM" ;;
    arch|manjaro|endeavouros|garuda)
        SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_ARCH" ;;
    opensuse*|sles)
        SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_OPENSUSE" ;;
    *)
        # Famille détectée via ID_LIKE
        case "$DISTRO_LIKE" in
            *debian*|*ubuntu*)
                SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_DEBIAN" ;;
            *fedora*|*rhel*|*centos*)
                SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_RPM" ;;
            *arch*)
                SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_ARCH" ;;
            *suse*)
                SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_OPENSUSE" ;;
            *)
                # Distro inconnue : on applique tous les services par sécurité
                SERVICES_TO_MASK="$SERVICES_TO_MASK $SERVICES_DEBIAN $SERVICES_RPM $SERVICES_ARCH $SERVICES_OPENSUSE"
                echo "[INFO] Distro inconnue, désactivation large des services bloquants." ;;
        esac ;;
esac

# Application du masquage
for SERVICE in $SERVICES_TO_MASK; do
    [ -z "$SERVICE" ] && continue
    ln -sf /dev/null "$SYSTEMD_DIR/$SERVICE"
    find "$SYSTEMD_DIR" -name "$SERVICE" -type l ! -path "$SYSTEMD_DIR/$SERVICE" -delete 2>/dev/null
done

echo "[OK] Services bloquants désactivés pour le live."

#_____________________________________________________________________________________________
# CONSTRUCTION DE LA LISTE DES DOSSIERS POUR mksquashfs
# On remplace /etc par le dossier temporaire dans la liste des sources.
echo "Création du squashfs..."
SQSFDIR=""
for i in $ROOTDIR; do
    if [ "$i" = "etc" ]; then
        # On utilise le /etc temporaire à la place du vrai
        [ -d "$RPG_ETC_TMP" ] && SQSFDIR="$SQSFDIR $RPG_ETC_TMP"
    else
        [ -d "/$i" ] && SQSFDIR="$SQSFDIR /$i"
    fi
done

if [ -z "$SQSFDIR" ]; then
    echo "[ERREUR] Aucun dossier valide dans ROOTDIR."
    rm -rf "$RPG_ETC_TMP"
    exit 1
fi

mksquashfs $SQSFDIR /respinguy-build-dir/LiveOS/squashfs.img \
    -comp xz \
    -b 1024K \
    -always-use-fragments \
    -keep-as-directory \
    -noappend \
    -wildcards \
    -e "proc/*"  "proc/.*" \
    -e "run/*"   "run/.*" \
    -e "tmp/*"   "tmp/.*" \
    -e "sys/*"   "sys/.*" \
    -e "dev/*" \
    -e "var/crash/*" \
    -e "var/tmp/*" \
    -e "root/.bash_history" "root/.cache" "root/.wget-hsts" \
    -e "home/*/.bash_history" "home/*/.cache" "home/*/.wget-hsts"

SQUASHFS_RESULT=$?
rm -rf "$RPG_ETC_TMP"

if [ $SQUASHFS_RESULT -ne 0 ]; then
    echo "[ERREUR] Échec de la création du squashfs."
    exit 1
fi

echo "Squashfs créé : $(du -sh /respinguy-build-dir/LiveOS/squashfs.img | cut -f1)"
read -p "Appuyez sur Entrée pour continuer..."

if [ -n "$RPGCONFIGUSER" ]; then
    bash /usr/share/ResPinGuy-File/script/rcurm
fi

#_____________________________________________________________________________________________
echo "Création de l'initrd..."
dracut \
    -N \
    --add "dmsquash-live" \
    --add "pollcdrom" \
    --omit "iscsi nbd fcoe fcoe-uefi" \
    --kver "$KERNEL" \
    --force \
    /respinguy-build-dir/initrd

if [ $? -ne 0 ]; then echo "[ERREUR] Échec de la création de l'initrd."; exit 1; fi
echo "initrd créé : $(du -sh /respinguy-build-dir/initrd | cut -f1)"
read -p "Appuyez sur Entrée pour continuer..."

#_____________________________________________________________________________________________
echo "Création de l'image ISO..."
cd / || exit 1
xorriso -as mkisofs \
    -r -J -joliet-long -l -iso-level 3 -cache-inodes \
    -isohybrid-mbr /usr/share/ResPinGuy-File/fichier/isohdpfx.bin \
    -partition_offset 16 -A "$RPGBUILDNAME" \
    -b isolinux/isolinux.bin -c isolinux/boot.cat \
    -no-emul-boot -boot-load-size 4 -boot-info-table \
    -o "$RPGHOME/$RPGBUILDNAME-$ARCH.iso" \
    /respinguy-build-dir/

if [ $? -ne 0 ]; then echo "[ERREUR] Échec de la création de l'ISO."; exit 1; fi

clear
echo "_ _ _"
echo "Build terminé avec succès !"
echo "ISO : $RPGHOME/$RPGBUILDNAME-$ARCH.iso"
echo "Taille : $(du -sh "$RPGHOME/$RPGBUILDNAME-$ARCH.iso" | cut -f1)"
echo "_ _ _"
