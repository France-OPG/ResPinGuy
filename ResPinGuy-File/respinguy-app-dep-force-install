#!/bin/bash
#_____________________________________________________________________________________________
# ResPinGuy - Installation forcée des dépendances
# Détection automatique du gestionnaire de paquets
allow_only_root() {
  if [ "0$UID" -ne 0 ]; then
     echo "Merci d'être en root pour lancer : $(basename $0)"; exit 1
  fi
}
allow_only_root

#_____________________________________________________________________________________________
# Détection du gestionnaire de paquets
detect_pkg_manager() {
    if   [ "$(type -p apt)"    ]; then echo "apt"
    elif [ "$(type -p dnf)"    ]; then echo "dnf"
    elif [ "$(type -p yum)"    ]; then echo "yum"
    elif [ "$(type -p pacman)" ]; then echo "pacman"
    elif [ "$(type -p zypper)" ]; then echo "zypper"
    elif [ "$(type -p emerge)" ]; then echo "emerge"
    else echo "unknown"
    fi
}

# Noms des paquets selon la distro
install_pkg() {
    TOOL="$1"
    PKG_MGR=$(detect_pkg_manager)

    case "$PKG_MGR" in
        apt)
            case "$TOOL" in
                git)            apt install -y git ;;
                wget)           apt install -y wget ;;
                nano)           apt install -y nano ;;
                mksquashfs)     apt install -y squashfs-tools ;;
                unsquashfs)     apt install -y squashfs-tools ;;
                dracut)         apt install -y dracut dracut-live ;;
                dracut-live)    apt install -y dracut-live ;;
                xorriso)        apt install -y xorriso ;;
                isolinux)       apt install -y isolinux ;;
            esac ;;
        dnf|yum)
            case "$TOOL" in
                git)            $PKG_MGR install -y git ;;
                wget)           $PKG_MGR install -y wget ;;
                nano)           $PKG_MGR install -y nano ;;
                mksquashfs)     $PKG_MGR install -y squashfs-tools ;;
                unsquashfs)     $PKG_MGR install -y squashfs-tools ;;
                dracut)         $PKG_MGR install -y dracut dracut-live dracut-squash ;;
                dracut-live)    $PKG_MGR install -y dracut-live ;;
                xorriso)        $PKG_MGR install -y xorriso ;;
                isolinux)       $PKG_MGR install -y syslinux ;;
            esac ;;
        pacman)
            case "$TOOL" in
                git)            pacman -S --noconfirm git ;;
                wget)           pacman -S --noconfirm wget ;;
                nano)           pacman -S --noconfirm nano ;;
                mksquashfs)     pacman -S --noconfirm squashfs-tools ;;
                unsquashfs)     pacman -S --noconfirm squashfs-tools ;;
                dracut)         pacman -S --noconfirm dracut ;;
                dracut-live)    pacman -S --noconfirm dracut ;;
                xorriso)        pacman -S --noconfirm libisoburn ;;
                isolinux)       pacman -S --noconfirm syslinux ;;
            esac ;;
        zypper)
            case "$TOOL" in
                git)            zypper install -y git ;;
                wget)           zypper install -y wget ;;
                nano)           zypper install -y nano ;;
                mksquashfs)     zypper install -y squashfs ;;
                unsquashfs)     zypper install -y squashfs ;;
                dracut)         zypper install -y dracut ;;
                dracut-live)    zypper install -y dracut ;;
                xorriso)        zypper install -y xorriso ;;
                isolinux)       zypper install -y syslinux ;;
            esac ;;
        emerge)
            case "$TOOL" in
                git)            emerge dev-vcs/git ;;
                wget)           emerge net-misc/wget ;;
                nano)           emerge app-editors/nano ;;
                mksquashfs)     emerge sys-fs/squashfs-tools ;;
                unsquashfs)     emerge sys-fs/squashfs-tools ;;
                dracut)         emerge sys-kernel/dracut ;;
                dracut-live)    emerge sys-kernel/dracut ;;
                xorriso)        emerge dev-libs/libisoburn ;;
                isolinux)       emerge sys-boot/syslinux ;;
            esac ;;
        unknown)
            echo "[ERREUR] Gestionnaire de paquets non reconnu."
            echo "         Installez manuellement : $TOOL"
            return 1 ;;
    esac
}

#_____________________________________________________________________________________________
PKG_MGR=$(detect_pkg_manager)
if [ "$PKG_MGR" = "unknown" ]; then
    echo "[ERREUR] Aucun gestionnaire de paquets reconnu sur ce système."
    echo "         Installez manuellement les dépendances manquantes."
    exit 1
fi

echo "Gestionnaire de paquets détecté : $PKG_MGR"
echo "Tentative d'installation forcée des dépendances manquantes..."
echo "---"

FIXED=0
FAILED=0

# git
if [ ! "$(type -p git)" ]; then
    echo "Installation de git..."
    install_pkg git && FIXED=$((FIXED+1)) || FAILED=$((FAILED+1))
fi

# wget
if [ ! "$(type -p wget)" ]; then
    echo "Installation de wget..."
    install_pkg wget && FIXED=$((FIXED+1)) || FAILED=$((FAILED+1))
fi

# nano
if [ ! "$(type -p nano)" ]; then
    echo "Installation de nano..."
    install_pkg nano && FIXED=$((FIXED+1)) || FAILED=$((FAILED+1))
fi

# mksquashfs + unsquashfs
if [ "$(mksquashfs 2>&1 | grep 'Xdict-size')" = "" ]; then
    echo "Installation de squashfs-tools..."
    install_pkg mksquashfs && FIXED=$((FIXED+1)) || FAILED=$((FAILED+1))
fi

# dracut
if [ ! "$(type -p dracut)" ]; then
    echo "Installation de dracut..."
    install_pkg dracut && FIXED=$((FIXED+1)) || FAILED=$((FAILED+1))
fi

# dracut-live (module dmsquash-live)
if [ "$(type -p dracut)" ] && [ ! "$(dracut --list-modules 2>/dev/null | grep dmsquash-live)" ]; then
    echo "Installation du module dracut-live..."
    install_pkg dracut-live && FIXED=$((FIXED+1)) || FAILED=$((FAILED+1))
fi

# xorriso
if [ ! "$(type -p xorriso)" ]; then
    echo "Installation de xorriso..."
    install_pkg xorriso && FIXED=$((FIXED+1)) || FAILED=$((FAILED+1))
fi

#_____________________________________________________________________________________________
echo "---"
echo "$FIXED dépendance(s) installée(s)."
[ $FAILED -gt 0 ] && echo "$FAILED dépendance(s) en échec. Installez-les manuellement."
echo "Relancez : respinguy-app-dep pour vérifier."
echo "---"
