#!/bin/bash
allow_only_root() {
  if [ "0$UID" -ne 0 ]; then echo "Merci d'être en root pour lancer : $(basename $0)"; exit 1; fi
}
allow_only_root
echo "Tentative d'installation forcée des dépendances manquantes..."

for tool in git wget bash sh nano uname xorriso; do
  if [ ! $(type -p $tool) ]; then
    echo "[INFO] $tool n'est pas installé. Installation forcée non disponible pour l'instant."
  fi
done

if [ "$(mksquashfs 2>&1 | grep 'Xdict-size')" = "" ]; then
  echo "[INFO] mksquashfs sans support xz. Installation forcée non disponible pour l'instant."
fi

if [ ! $(type -p dracut) ]; then
  echo "[INFO] dracut n'est pas installé. Tentative de compilation..."
  if [ ! $(type -p gcc) ]; then echo "[ERREUR] gcc manquant, compilation impossible."; exit 1; fi
  if [ ! $(type -p make) ]; then echo "[ERREUR] make manquant, compilation impossible."; exit 1; fi
  git clone https://github.com/dracutdevs/dracut.git /tmp/dracut-build || { echo "[ERREUR] Échec du téléchargement."; exit 1; }
  cd /tmp/dracut-build
  ./configure && make || { echo "[ERREUR] Échec de la compilation."; cd /; rm -rf /tmp/dracut-build; exit 1; }
  make install || { echo "[ERREUR] Échec de l'installation."; }
  cd / && rm -rf /tmp/dracut-build
  echo "[OK] dracut installé."
fi

echo "---"
echo "Certaines dépendances ont pu être résolues."
echo "Pour les autres, installez-les via votre gestionnaire de paquets."
echo "---"
